# ====================================================================
# ORNEK ORTAM DEGISKENLERI
# Bu dosyayi kopyalayip ".env" olarak kaydedin ve degerleri doldurun.
# Hostinger panelinde bu degiskenleri "Environment Variables" bolumunden
# de tanimlayabilirsiniz.
# ====================================================================

# Uygulamanin calisacagi port (Hostinger genelde otomatik atar)
PORT=3000

# Oturum guvenligi icin gizli anahtar. Uzun, rastgele bir metin girin.
# Ornek uretmek icin: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=buraya-uzun-rastgele-bir-anahtar-yazin

# Ilk acilista olusturulacak YONETICI hesabi
# Site ilk kez calistiginda bu bilgilerle admin kullanicisi otomatik olusur.
# Giris yaptiktan sonra sifrenizi panelden degistirebilirsiniz.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Degistir.123

# Yuklenebilecek en buyuk dosya boyutu (MB cinsinden)
MAX_UPLOAD_MB=50

# ====================================================================
# KALICI VERI KLASORLERI (COK ONEMLI - Hostinger icin)
# ====================================================================
# Hostinger her deploy'da (Git Pull) uygulama klasorunu temizleyebilir ve
# bu da yuklenen evraklarin/kayitlarin SILINMESINE yol acar.
# Bunu onlemek icin asagidaki iki klasoru, uygulama klasorunun DISINDA
# (Git'in dokunmadigi bir yerde) gosterin. Ornek (kendi kullanici adinizla):
#
#   DATA_DIR=/home/u123456789/evrak-veri
#   UPLOADS_DIR=/home/u123456789/evrak-dosyalar
#
# Bu klasorleri Hostinger Dosya Yoneticisi'nden bir kez olusturun.
# Bos birakirsaniz uygulama klasoru icindeki data/ ve uploads/ kullanilir
# (yerelde calisirken sorun degil, ama Hostinger'da MUTLAKA doldurun).
DATA_DIR=
UPLOADS_DIR=
