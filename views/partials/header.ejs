<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · Bilişim Evrak</title>
  <link rel="stylesheet" href="/public/css/style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📂</text></svg>" />
</head>
<body>
  <% if (currentUser) { %>
  <div class="app-shell">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-head">
        <a href="/" class="sidebar-brand">📂 <span>Bilişim Evrak</span></a>
      </div>
      <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= currentPath === '/' ? 'active' : '' %>">
          <span class="nav-ico">🏠</span><span class="nav-label">Ana Sayfa</span>
        </a>

        <div class="nav-section">Evraklar</div>
        <% navCategories.forEach(function(cat){ %>
          <a href="/kategori/<%= cat.slug %>" class="nav-item <%= currentPath === '/kategori/' + cat.slug ? 'active' : '' %>">
            <span class="nav-ico"><%= cat.icon %></span><span class="nav-label"><%= cat.name %></span>
          </a>
        <% }); %>

        <% if (currentUser.role === 'admin') { %>
          <div class="nav-section">Yönetim</div>
          <a href="/yukle" class="nav-item <%= currentPath === '/yukle' ? 'active' : '' %>"><span class="nav-ico">⬆️</span><span class="nav-label">Evrak Yükle</span></a>
          <a href="/yonetim/kategoriler" class="nav-item <%= currentPath === '/yonetim/kategoriler' ? 'active' : '' %>"><span class="nav-ico">🗃️</span><span class="nav-label">Kategoriler</span></a>
          <a href="/yonetim/donemler" class="nav-item <%= currentPath === '/yonetim/donemler' ? 'active' : '' %>"><span class="nav-ico">📅</span><span class="nav-label">Dönemler</span></a>
          <a href="/yonetim/kullanicilar" class="nav-item <%= currentPath === '/yonetim/kullanicilar' ? 'active' : '' %>"><span class="nav-ico">👤</span><span class="nav-label">Kullanıcılar</span><% if (pendingCount > 0) { %><span class="nav-badge"><%= pendingCount %></span><% } %></a>
          <a href="/yonetim/yedek" class="nav-item <%= currentPath === '/yonetim/yedek' ? 'active' : '' %>"><span class="nav-ico">💾</span><span class="nav-label">Yedek</span></a>
        <% } %>

        <div class="nav-section">Hesap</div>
        <a href="/hesabim" class="nav-item <%= currentPath === '/hesabim' ? 'active' : '' %>"><span class="nav-ico">🔑</span><span class="nav-label">Hesabım</span></a>
        <form action="/cikis" method="post" class="nav-logout">
          <button type="submit" class="nav-item"><span class="nav-ico">🚪</span><span class="nav-label">Çıkış Yap</span></button>
        </form>
      </nav>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="main-area">
      <header class="main-topbar">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Menü">☰</button>
        <form action="/ara" method="get" class="search-form">
          <input type="search" name="q" placeholder="Evrak ara..." value="<%= typeof q !== 'undefined' ? q : '' %>" />
          <button type="submit" aria-label="Ara">🔍</button>
        </form>
        <div class="topbar-user">
          <span class="user-name"><%= currentUser.fullName || currentUser.username %></span>
          <span class="user-avatar"><%= (currentUser.fullName || currentUser.username).charAt(0).toUpperCase() %></span>
        </div>
      </header>

      <main class="content">
        <% if (typeof flash !== 'undefined' && flash) { %>
          <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
        <% } %>
  <% } else { %>
    <main class="container">
      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
      <% } %>
  <% } %>
