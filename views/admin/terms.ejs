<%- include('../partials/header') %>

<div class="breadcrumb"><a href="/">Ana Sayfa</a> / Yonetim / Donemler</div>

<div class="page-head">
  <h1>📅 Ogretim Donemi Yonetimi</h1>
</div>

<div class="form-card">
  <h2 class="section-title">Yeni Donem Ekle</h2>
  <form action="/yonetim/donemler" method="post" class="form-inline">
    <input type="text" name="name" placeholder="Orn: 2025-2026" required style="flex:1" />
    <button type="submit" class="btn btn-primary">Ekle</button>
  </form>
</div>

<div class="table-wrap">
  <table class="table">
    <thead>
      <tr><th>Donem</th><th>Evrak Sayisi</th><th></th></tr>
    </thead>
    <tbody>
      <% terms.forEach(function(t) { %>
        <tr>
          <td><strong>📅 <%= t.name %></strong></td>
          <td><span class="badge"><%= t.count %></span></td>
          <td class="cell-actions">
            <form action="/yonetim/donemler/<%= t.id %>/sil" method="post" class="js-confirm" data-confirm="'<%= t.name %>' donemini silmek istiyor musunuz? (Evraklar silinmez, sadece donem bilgisi kaldirilir.)">
              <button type="submit" class="btn btn-sm btn-danger">Sil</button>
            </form>
          </td>
        </tr>
      <% }); %>
      <% if (terms.length === 0) { %>
        <tr><td colspan="3" class="muted">Henuz donem yok.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
