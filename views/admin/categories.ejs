<%- include('../partials/header') %>

<div class="breadcrumb"><a href="/">Ana Sayfa</a> / Yonetim / Kategoriler</div>

<div class="page-head">
  <h1>🗃️ Kategori Yonetimi</h1>
</div>

<div class="form-card">
  <h2 class="section-title">Yeni Kategori Ekle</h2>
  <form action="/yonetim/kategoriler" method="post" class="form-inline">
    <input type="text" name="icon" placeholder="📁" maxlength="4" style="width:70px" />
    <input type="text" name="name" placeholder="Kategori adi" required style="flex:1" />
    <button type="submit" class="btn btn-primary">Ekle</button>
  </form>
</div>

<div class="table-wrap">
  <table class="table">
    <thead>
      <tr><th>Simge</th><th>Ad</th><th>Evrak Sayisi</th><th></th></tr>
    </thead>
    <tbody>
      <% categories.forEach(function(cat) { %>
        <tr>
          <td class="cell-icon"><%= cat.icon %></td>
          <td><%= cat.name %></td>
          <td><span class="badge"><%= cat.count %></span></td>
          <td class="cell-actions">
            <form action="/yonetim/kategoriler/<%= cat.id %>/sil" method="post" class="js-confirm" data-confirm="'<%= cat.name %>' kategorisini silmek istiyor musunuz?">
              <button type="submit" class="btn btn-sm btn-danger" <%= cat.count > 0 ? 'disabled title="Once evraklari silin"' : '' %>>Sil</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
