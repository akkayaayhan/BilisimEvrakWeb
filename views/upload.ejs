<%- include('partials/header') %>

<div class="breadcrumb"><a href="/">Ana Sayfa</a> / Evrak Yukle</div>

<div class="form-card">
  <h1>⬆️ Evrak Yukle</h1>

  <form action="/yukle" method="post" enctype="multipart/form-data" class="form" id="uploadForm">
    <label>
      Baslik
      <input type="text" name="title" placeholder="Orn: 10. Sinif Yillik Plani 2025-2026" required />
    </label>

    <label>
      Kategori
      <select name="categoryId" id="categorySelect" required>
        <option value="">— Kategori secin —</option>
        <% categories.forEach(function(cat) { %>
          <option value="<%= cat.id %>" <%= preselect === cat.id ? 'selected' : '' %>><%= cat.icon %> <%= cat.name %></option>
        <% }); %>
      </select>
    </label>

    <label>
      Alt Kategori <small class="muted">(istege bagli — orn. Mobil Uygulamalar)</small>
      <select name="subcategoryId" id="subcategorySelect">
        <option value="">— Alt kategori yok —</option>
        <option value="__new__">➕ Yeni alt kategori ekle...</option>
      </select>
    </label>

    <label id="newSubWrap" style="display:none">
      Yeni Alt Kategori Adi
      <input type="text" name="newSubcategory" id="newSubInput" placeholder="Orn: Mobil Uygulamalar" />
    </label>

    <label>
      Ogretim Donemi <small class="muted">(istege bagli)</small>
      <select name="termId" id="termSelect">
        <option value="">— Donem yok —</option>
        <% terms.forEach(function(t) { %>
          <option value="<%= t.id %>"><%= t.name %></option>
        <% }); %>
        <option value="__new__">➕ Yeni donem ekle...</option>
      </select>
    </label>

    <label id="newTermWrap" style="display:none">
      Yeni Donem
      <input type="text" name="newTerm" id="newTermInput" placeholder="Orn: 2025-2026" />
    </label>

    <label>
      Aciklama (istege bagli)
      <textarea name="description" rows="3" placeholder="Kisa not..."></textarea>
    </label>

    <label>
      Dosya
      <input type="file" name="file" required />
      <small class="muted">PDF, Word, Excel, PowerPoint, resim, zip vb. desteklenir.</small>
    </label>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Yukle</button>
      <a href="/" class="btn btn-ghost">Iptal</a>
    </div>
  </form>
</div>

<script>
  // Tum alt kategoriler (kategoriye gore filtrelenecek)
  var ALL_SUBS = <%- JSON.stringify(subcategories.map(function(s){ return { id: s.id, categoryId: s.categoryId, name: s.name }; })) %>;

  var categorySelect = document.getElementById('categorySelect');
  var subSelect = document.getElementById('subcategorySelect');
  var newSubWrap = document.getElementById('newSubWrap');
  var newSubInput = document.getElementById('newSubInput');

  function rebuildSubs() {
    var catId = categorySelect.value;
    var subs = ALL_SUBS.filter(function (s) { return s.categoryId === catId; });
    subSelect.innerHTML = '';
    subSelect.appendChild(new Option('— Alt kategori yok —', ''));
    subs.forEach(function (s) {
      subSelect.appendChild(new Option(s.name, s.id));
    });
    subSelect.appendChild(new Option('➕ Yeni alt kategori ekle...', '__new__'));
    toggleNewInput();
  }

  function toggleNewInput() {
    if (subSelect.value === '__new__') {
      newSubWrap.style.display = '';
    } else {
      newSubWrap.style.display = 'none';
      newSubInput.value = '';
    }
  }

  categorySelect.addEventListener('change', rebuildSubs);
  subSelect.addEventListener('change', toggleNewInput);

  // Donem: "yeni ekle" secilince metin kutusunu goster
  var termSelect = document.getElementById('termSelect');
  var newTermWrap = document.getElementById('newTermWrap');
  var newTermInput = document.getElementById('newTermInput');
  function toggleNewTerm() {
    if (termSelect.value === '__new__') {
      newTermWrap.style.display = '';
    } else {
      newTermWrap.style.display = 'none';
      newTermInput.value = '';
    }
  }
  termSelect.addEventListener('change', toggleNewTerm);

  // Gonderirken "__new__" secimlerini temizle (metin kutulari kullanilsin)
  document.getElementById('uploadForm').addEventListener('submit', function () {
    if (subSelect.value === '__new__') subSelect.value = '';
    if (termSelect.value === '__new__') termSelect.value = '';
  });

  // Sayfa acilirken (kategori onceden secili gelebilir) alt kategorileri doldur
  rebuildSubs();
</script>

<%- include('partials/footer') %>
